<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Carmen Boutique &mdash; Fashion, Perfumes &amp; Accessories</title>
  <meta name="description" content="Shop curated womens and mens clothing, shoes, perfumes and accessories. Order on WhatsApp, delivered anywhere in South Africa." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <!-- NAV -->
  <nav class="top-nav">
    <a class="nav-brand" href="/">Carmen Boutique</a>
    <div class="nav-links">
      <a href="/#catalog">Shop</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/cart" style="position: relative;">
        🛒 Cart
        <span id="cart-badge" style="position: absolute; top: -8px; right: -12px; background: var(--pink); color: white; font-size: 0.7rem; font-weight: 700; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; display: none;"></span>
      </a>
      <a class="nav-wa" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">WhatsApp us</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <div class="hero-inner">
      <span class="hero-eyebrow">New arrivals &bull; Free local shipping</span>
      <h1>Style that speaks<br /><em>your language</em></h1>
      <p class="hero-sub">
        Curated clothing, shoes, perfumes &amp; accessories &mdash; ordered on WhatsApp,
        delivered straight to your door anywhere in South Africa.
      </p>
      <a class="hero-cta" href="#catalog">Shop the collection</a>
    </div>
  </header>

  <!-- HOW IT WORKS -->
  <section class="how-it-works" id="how-it-works">
    <span class="section-label">Simple &amp; easy</span>
    <h2>How it works</h2>
    <div class="steps">
      <div class="step">
        <span class="step-icon">&#128717;</span>
        <h3>Browse</h3>
        <p>Explore our curated collection of clothing, shoes, perfumes and accessories. Pick your size and style.</p>
      </div>
      <div class="step-divider">&#8594;</div>
      <div class="step">
        <span class="step-icon">&#128172;</span>
        <h3>WhatsApp us</h3>
        <p>Tap the &ldquo;Order on WhatsApp&rdquo; button on any product. We&rsquo;ll confirm your order and send payment details.</p>
      </div>
      <div class="step-divider">&#8594;</div>
      <div class="step">
        <span class="step-icon">&#128230;</span>
        <h3>We deliver</h3>
        <p>We ship via Pudo or The Courier Guy, straight to your door anywhere in South Africa.</p>
      </div>
    </div>
  </section>

  <!-- CATALOG -->
  <section class="catalog-section" id="catalog">
    <div class="catalog-header">
      <span class="section-label">Our collection</span>
      <h2>Shop everything</h2>
      <p class="sub">Filter by category or browse all &mdash; every piece is ready to order on WhatsApp.</p>
      <% if (storefrontSettings.hideOutOfStock) { %>
        <span class="stock-mode">&#10003; Showing in-stock items only</span>
      <% } %>
      <form class="catalog-filter" method="GET" action="/">
        <% categories.forEach(function(category) { %>
          <button
            type="submit"
            name="category"
            value="<%= category %>"
            class="filter-pill <%= selectedCategory === category ? 'active' : '' %>"
          ><%= category %></button>
        <% }); %>
      </form>
    </div>

    <% if (!products.length) { %>
      <div class="catalog">
        <div class="empty-state">
          <h2>Nothing here yet</h2>
          <p>Try a different category, or check back soon for new arrivals.</p>
        </div>
      </div>
    <% } else { %>
      <div class="catalog">
        <% products.forEach(function(product) { %>
          <article class="product-card" data-product-id="<%= product.id %>">
            <div class="media-wrap">
              <% if (product.image_path) { %>
                <img src="<%= product.image_path %>" alt="<%= product.name %>" loading="lazy" />
              <% } else { %>
                <div class="placeholder">No image</div>
              <% } %>
              <span class="category-tag"><%= product.gender %></span>
            </div>

            <div class="product-meta">
              <h3><%= product.name %></h3>
              <p class="description"><%= product.description || '' %></p>
              <p class="price">R <%= Number(product.price).toFixed(2) %></p>

              <div style="margin-bottom: 1rem;">
                <label style="display: block; font-size: 0.85rem; font-weight: 600; color: var(--ink); margin-bottom: 0.4rem;">Select option:</label>
                <select style="width: 100%; border: 1.5px solid var(--card-border); border-radius: 6px; padding: 0.5rem; font-size: 0.9rem; color: var(--ink); background: white;">
                  <option value="">-- Choose size/variant --</option>
                  <% product.optionsArray.forEach(function(option) { %>
                    <option value="<%= option.trim() %>"><%= option.trim() %></option>
                  <% }); %>
                </select>
              </div>

              <p class="stock <%= product.in_stock ? 'yes' : 'no' %>">
                <%= product.in_stock ? '✓ In stock' : '✗ Out of stock' %>
              </p>

              <% if (product.in_stock) { %>
                <button class="wa-button add-to-cart-btn" style="cursor: pointer;" onclick="addToCart({ id: <%= product.id %>, name: '<%= product.name.replace(/'/g, "\\'") %>', price: <%= product.price %>, category: '<%= product.gender %>', image: '<%= product.image_path %>' })">
                  + Add to Cart
                </button>
              <% } else { %>
                <button class="wa-button disabled" disabled>Out of stock</button>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>Carmen Boutique</h3>
        <p>Your one-stop fashion destination &mdash; curated with love and delivered with care across South Africa.</p>
      </div>
      <div class="footer-links">
        <h4>Quick links</h4>
        <a href="/">Shop all</a>
        <a href="#how-it-works">How it works</a>
        <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">Contact us</a>
      </div>
      <div class="footer-wa">
        <h4>Place an order</h4>
        <p>Questions? We reply fast. Chat with us directly on WhatsApp.</p>
        <a class="footer-wa-btn" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">Chat with us</a>
      </div>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Carmen Boutique &mdash; All rights reserved.</p>
  </footer>

  <script src="/cart.js"></script>

</body>
</html>
