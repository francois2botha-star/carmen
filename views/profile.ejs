<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Create Profile &mdash; Carmen Boutique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <style>
    .profile-container { max-width: 600px; margin: 0 auto; padding: 2rem; background: white; border-radius: 14px; box-shadow: 0 4px 20px rgba(216,27,96,0.12); }
    .form-section { margin-bottom: 2rem; }
    .form-section h3 { font-family: 'Playfair Display', serif; color: var(--pink); margin-bottom: 1rem; font-size: 1.2rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-row.full { grid-template-columns: 1fr; }
    .form-group { display: grid; gap: 0.3rem; }
    .form-group label { font-size: 0.9rem; font-weight: 500; color: var(--ink); }
    .form-group input, .form-group textarea { width: 100%; border: 1.5px solid var(--card-border); border-radius: 8px; padding: 0.65rem 0.85rem; font: inherit; }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--pink); box-shadow: 0 0 0 3px rgba(216,27,96,0.08); }
    .button-group { display: flex; gap: 1rem; margin-top: 2rem; }
    .button-group button { flex: 1; padding: 0.8rem; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; font-size: 0.95rem; transition: all 0.22s ease; }
    .btn-primary { background: var(--pink); color: white; }
    .btn-primary:hover { background: var(--pink-dark); }
    .btn-secondary { background: transparent; color: var(--pink); border: 2px solid var(--pink); }
    .btn-secondary:hover { background: var(--pink-pale); }
  </style>
</head>
<body>

  <nav class="top-nav">
    <a class="nav-brand" href="/">Carmen Boutique</a>
    <div class="nav-links">
      <div class="nav-dropdown">
        <a href="/">Shop</a>
        <div class="nav-submenu">
          <% categories.forEach((category) => { %>
            <a href="/?category=<%= encodeURIComponent(category) %>"><%= category %></a>
          <% }) %>
        </div>
      </div>
      <a href="/cart">Cart</a>
    </div>
  </nav>

  <header class="hero" style="padding: 3rem 2rem;">
    <div class="hero-inner">
      <h1>Your Profile</h1>
      <p class="hero-sub">We need your details to process your order.</p>
    </div>
  </header>

  <main style="max-width: 900px; margin: 3rem auto; padding: 0 2rem;">
    <div class="profile-container">
      <form id="profileForm">
        <div class="form-section">
          <h3>Personal Information</h3>
          <div class="form-row">
            <div class="form-group">
              <label>First Name *</label>
              <input type="text" name="firstName" required />
            </div>
            <div class="form-group">
              <label>Last Name *</label>
              <input type="text" name="lastName" required />
            </div>
          </div>
          <div class="form-row full">
            <div class="form-group">
              <label>Email *</label>
              <input type="email" name="email" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Phone *</label>
              <input type="tel" name="phone" placeholder="0712345678" required />
            </div>
            <div class="form-group">
              <label>Alternative Phone</label>
              <input type="tel" name="altPhone" placeholder="Optional" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h3>Delivery Address</h3>
          <div class="form-row full">
            <div class="form-group">
              <label>Street Address *</label>
              <input type="text" name="address" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>City/Town *</label>
              <input type="text" name="city" required />
            </div>
            <div class="form-group">
              <label>Postal Code *</label>
              <input type="text" name="postalCode" required />
            </div>
          </div>
          <div class="form-row full">
            <div class="form-group">
              <label>Province *</label>
              <input type="text" name="province" placeholder="e.g. Gauteng, Western Cape" required />
            </div>
          </div>
        </div>

        <div class="button-group">
          <button type="button" class="btn-secondary" onclick="window.history.back()">Back</button>
          <button type="submit" class="btn-primary">Save & Proceed</button>
        </div>
      </form>
    </div>
  </main>

  <script>
    document.getElementById('profileForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = {
        firstName: this.firstName.value.trim(),
        lastName: this.lastName.value.trim(),
        email: this.email.value.trim(),
        phone: this.phone.value.trim(),
        altPhone: this.altPhone.value.trim(),
        address: this.address.value.trim(),
        city: this.city.value.trim(),
        postalCode: this.postalCode.value.trim(),
        province: this.province.value.trim()
      };

      localStorage.setItem('userProfile', JSON.stringify(formData));
      window.location.href = '/checkout';
    });

    // Load existing profile if available
    const saved = localStorage.getItem('userProfile');
    if (saved) {
      const profile = JSON.parse(saved);
      document.querySelector('input[name="firstName"]').value = profile.firstName || '';
      document.querySelector('input[name="lastName"]').value = profile.lastName || '';
      document.querySelector('input[name="email"]').value = profile.email || '';
      document.querySelector('input[name="phone"]').value = profile.phone || '';
      document.querySelector('input[name="altPhone"]').value = profile.altPhone || '';
      document.querySelector('input[name="address"]').value = profile.address || '';
      document.querySelector('input[name="city"]').value = profile.city || '';
      document.querySelector('input[name="postalCode"]').value = profile.postalCode || '';
      document.querySelector('input[name="province"]').value = profile.province || '';
    }
  </script>

</body>
</html>
