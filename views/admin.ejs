<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin | Carmen Boutique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="admin-hero">
    <h1>Admin Panel</h1>
    <p>Manage your products and categories.</p>
    <div class="admin-hero-actions">
      <a href="/">View Store &rarr;</a>
      <form action="/admin/logout" method="POST" class="admin-logout-form">
        <button type="submit" class="btn-secondary">Logout</button>
      </form>
    </div>
  </header>

  <main class="admin-layout">
    <section class="admin-card">
      <h2>Add Product</h2>
      <% if (error) { %>
        <p class="message error"><%= error %></p>
      <% } %>
      <% if (success) { %>
        <p class="message success"><%= success %></p>
      <% } %>

      <form action="/admin/products" method="POST" enctype="multipart/form-data" class="admin-form">
        <label>
          Product Name
          <input type="text" name="name" required />
        </label>

        <label>
          Description
          <textarea name="description" rows="3" placeholder="e.g. Soft stretch cotton shirt with a relaxed fit (optional)"></textarea>
        </label>

        <label>
          Price (ZAR)
          <input type="number" name="price" min="1" step="0.01" placeholder="e.g. 499.00" required />
        </label>

        <label>
          Sizes/Volumes (comma-separated)
          <input type="text" name="options" placeholder="S, M, L or 50ml, 100ml" required />
        </label>

        <label>
          Category
          <select name="category" class="category-select" data-custom-target="add-custom-category" required>
            <option value="">Select category</option>
            <% categoryOptions.forEach((categoryOption) => { %>
              <option value="<%= categoryOption %>"><%= categoryOption %></option>
            <% }) %>
            <option value="__custom__">Other (custom)</option>
          </select>
        </label>

        <label id="add-custom-category" class="custom-category-field hidden">
          Custom Category
          <input type="text" name="customCategory" placeholder="Type custom category" />
        </label>

        <div class="image-upload-group">
          <p class="image-upload-title">Product Images (up to 5)</p>
          <div class="image-upload-list">
            <% for (let i = 1; i <= 5; i += 1) { %>
              <div class="image-upload-row">
                <label class="image-upload-label" for="add-image-<%= i %>">Image <%= i %></label>
                <input id="add-image-<%= i %>" type="file" name="images" accept="image/*" data-preview-target="add-image-preview-<%= i %>" />
                <img id="add-image-preview-<%= i %>" class="image-preview-thumb hidden" alt="Selected image <%= i %> preview" />
              </div>
            <% } %>
          </div>
        </div>

        <label class="checkbox-line">
          <input type="checkbox" name="inStock" value="1" checked />
          In stock
        </label>

        <button type="submit">Save Product</button>
      </form>
    </section>

    <section class="admin-card">
      <h2>Manage Categories</h2>
      <form action="/admin/categories" method="POST" class="admin-form" style="margin-bottom:1rem;">
        <label>
          New Category
          <input type="text" name="name" placeholder="e.g. Dresses" required />
        </label>
        <button type="submit">Add Category</button>
      </form>

      <div class="admin-list" style="max-height: 220px;">
        <% categories.forEach((categoryItem) => { %>
          <article class="admin-item" style="display:flex;align-items:center;justify-content:space-between;gap:0.8rem;">
            <h3 style="margin:0;"><%= categoryItem.name %></h3>
            <form action="/admin/categories/<%= categoryItem.id %>/delete" method="POST">
              <button type="submit" class="btn-danger">Remove</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="admin-card" style="grid-column: 1 / -1;">
      <h2>Current Products</h2>
      <% if (!products.length) { %>
        <p>No products yet.</p>
      <% } %>

      <div class="admin-list">
        <% products.forEach((product) => { %>
          <article class="admin-item">
            <div class="admin-product-head">
              <% if (product.primary_image_path || product.image_path) { %>
                <img
                  class="admin-product-thumb"
                  src="<%= product.primary_image_path || product.image_path %>"
                  alt="<%= product.name %>"
                  loading="lazy"
                />
              <% } %>
              <div>
              <h3><a href="/products/<%= product.id %>" style="text-decoration:none;color:inherit;"><%= product.name %></a></h3>
              <p class="meta">R <%= Number(product.price).toFixed(2) %> &bull; <%= product.gender %> &bull; <%= product.in_stock ? 'In stock' : 'Out of stock' %></p>
              </div>
            </div>

            <form action="/admin/products/<%= product.id %>/update" method="POST" enctype="multipart/form-data" class="edit-form">
              <input type="text" name="name" value="<%= product.name %>" placeholder="Product name" required />
              <textarea name="description" rows="2" placeholder="e.g. Lightweight fragrance, citrus top notes (optional)"><%= product.description %></textarea>
              <input type="number" name="price" min="1" step="0.01" value="<%= Number(product.price).toFixed(2) %>" placeholder="e.g. 899.00" required />
              <input type="text" name="options" value="<%= product.optionsArray.join(', ') %>" placeholder="e.g. S, M, L or 30ml, 50ml" required />
              <% const isCustomCategory = !categoryOptions.includes(product.gender); %>
              <select name="category" class="category-select" data-custom-target="edit-custom-<%= product.id %>" required>
                <option value="">Select category</option>
                <% categoryOptions.forEach((categoryOption) => { %>
                  <option value="<%= categoryOption %>" <%= product.gender === categoryOption ? 'selected' : '' %>><%= categoryOption %></option>
                <% }) %>
                <option value="__custom__" <%= isCustomCategory ? 'selected' : '' %>>Other (custom)</option>
              </select>
              <input
                id="edit-custom-<%= product.id %>"
                class="custom-category-field <%= isCustomCategory ? '' : 'hidden' %>"
                type="text"
                name="customCategory"
                value="<%= isCustomCategory ? product.gender : '' %>"
                placeholder="Type custom category"
              />
              <label class="checkbox-line">
                <input type="checkbox" name="inStock" value="1" <%= product.in_stock ? 'checked' : '' %> />
                In stock
              </label>
              <div class="image-upload-group">
                <p class="image-upload-title">Replace gallery images (up to 5)</p>
                <div class="image-upload-list">
                  <% for (let i = 1; i <= 5; i += 1) { %>
                    <div class="image-upload-row">
                      <label class="image-upload-label" for="edit-<%= product.id %>-image-<%= i %>">Image <%= i %></label>
                      <input id="edit-<%= product.id %>-image-<%= i %>" type="file" name="images" accept="image/*" data-preview-target="edit-<%= product.id %>-image-preview-<%= i %>" />
                      <img id="edit-<%= product.id %>-image-preview-<%= i %>" class="image-preview-thumb hidden" alt="Replacement image <%= i %> preview" />
                    </div>
                  <% } %>
                </div>
              </div>
              <button type="submit">Update</button>
            </form>

            <form action="/admin/products/<%= product.id %>/delete" method="POST" class="delete-form">
              <button type="submit" class="btn-danger">Delete</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="admin-card" style="grid-column: 1 / -1;">
      <h2>Order History</h2>
      <% if (!orders.length) { %>
        <p>No orders yet.</p>
      <% } %>

      <div class="admin-list" style="max-height: 60vh;">
        <% orders.forEach((order) => { %>
          <article class="admin-item">
            <h3>Order #<%= order.id %> &bull; <%= order.customer_name %></h3>
            <p class="meta">
              <strong>Status:</strong> <%= order.status %> &bull;
              <strong>Total:</strong> R <%= Number(order.items_total).toFixed(2) %> &bull;
              <strong>Date:</strong> <%= new Date(order.created_at).toLocaleString() %>
            </p>
            <p class="meta">
              <strong>Phone:</strong> <%= order.customer_phone || 'N/A' %> &bull;
              <strong>Email:</strong> <%= order.customer_email || 'N/A' %>
            </p>
            <p class="meta">
              <strong>Address:</strong>
              <%= [order.delivery_address, order.delivery_city, order.delivery_province, order.delivery_postal_code].filter(Boolean).join(', ') || 'N/A' %>
            </p>

            <% const orderItems = Array.isArray(order.items_json) ? order.items_json : []; %>
            <% if (orderItems.length) { %>
              <div class="order-items-admin">
                <% orderItems.forEach((item) => { %>
                  <div class="order-item-admin-row">
                    <span><%= item.name %> (<%= item.option %>) × <%= item.quantity %></span>
                    <span>R <%= Number(item.price * item.quantity).toFixed(2) %></span>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <form action="/admin/orders/<%= order.id %>/status" method="POST" class="admin-order-actions">
              <% orderStatuses.forEach((status) => { %>
                <button
                  type="submit"
                  name="status"
                  value="<%= status %>"
                  class="<%= order.status === status ? '' : 'btn-secondary' %>"
                >
                  <%= status %>
                </button>
              <% }) %>
            </form>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('.category-select').forEach((select) => {
      const targetId = select.dataset.customTarget;
      const target = document.getElementById(targetId);
      if (!target) {
        return;
      }

      const toggleCustomField = () => {
        if (select.value === '__custom__') {
          target.classList.remove('hidden');
        } else {
          target.classList.add('hidden');
          const input = target.querySelector('input');
          if (input) {
            input.value = '';
          }
        }
      };

      select.addEventListener('change', toggleCustomField);
      toggleCustomField();
    });

    document.querySelectorAll('input[type="file"][data-preview-target]').forEach((input) => {
      input.addEventListener('change', () => {
        const targetId = input.dataset.previewTarget;
        const preview = document.getElementById(targetId);
        if (!preview) {
          return;
        }

        const file = input.files && input.files[0];
        if (!file) {
          preview.removeAttribute('src');
          preview.classList.add('hidden');
          return;
        }

        if (!file.type.startsWith('image/')) {
          preview.removeAttribute('src');
          preview.classList.add('hidden');
          return;
        }

        const reader = new FileReader();
        reader.onload = () => {
          preview.src = reader.result;
          preview.classList.remove('hidden');
        };
        reader.readAsDataURL(file);
      });
    });
  </script>
</body>
</html>
