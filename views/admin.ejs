<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin | Carmen Boutique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="admin-hero">
    <h1>Admin Panel</h1>
    <p>Manage your products and categories.</p>
    <div style="display:flex;justify-content:center;gap:0.7rem;flex-wrap:wrap;">
      <a href="/">View Store &rarr;</a>
      <form action="/admin/logout" method="POST">
        <button type="submit" class="btn-secondary">Logout</button>
      </form>
    </div>
  </header>

  <main class="admin-layout">
    <section class="admin-card">
      <h2>Add Product</h2>
      <% if (error) { %>
        <p class="message error"><%= error %></p>
      <% } %>
      <% if (success) { %>
        <p class="message success"><%= success %></p>
      <% } %>

      <form action="/admin/products" method="POST" enctype="multipart/form-data" class="admin-form">
        <label>
          Product Name
          <input type="text" name="name" required />
        </label>

        <label>
          Description
          <textarea name="description" rows="3" placeholder="Optional"></textarea>
        </label>

        <label>
          Price (ZAR)
          <input type="number" name="price" min="1" step="0.01" required />
        </label>

        <label>
          Options (comma-separated)
          <input type="text" name="options" placeholder="S, M, L or 50ml, 100ml" required />
        </label>

        <label>
          Category
          <select name="category" class="category-select" data-custom-target="add-custom-category" required>
            <option value="">Select category</option>
            <% categoryOptions.forEach((categoryOption) => { %>
              <option value="<%= categoryOption %>"><%= categoryOption %></option>
            <% }) %>
            <option value="__custom__">Other (custom)</option>
          </select>
        </label>

        <label id="add-custom-category" class="custom-category-field hidden">
          Custom Category
          <input type="text" name="customCategory" placeholder="Type custom category" />
        </label>

        <label>
          Product Images (up to 5)
          <input type="file" name="images" accept="image/*" multiple />
        </label>

        <label class="checkbox-line">
          <input type="checkbox" name="inStock" value="1" checked />
          In stock
        </label>

        <button type="submit">Save Product</button>
      </form>
    </section>

    <section class="admin-card">
      <h2>Manage Categories</h2>
      <form action="/admin/categories" method="POST" class="admin-form" style="margin-bottom:1rem;">
        <label>
          New Category
          <input type="text" name="name" placeholder="e.g. Dresses" required />
        </label>
        <button type="submit">Add Category</button>
      </form>

      <div class="admin-list" style="max-height: 220px;">
        <% categories.forEach((categoryItem) => { %>
          <article class="admin-item" style="display:flex;align-items:center;justify-content:space-between;gap:0.8rem;">
            <h3 style="margin:0;"><%= categoryItem.name %></h3>
            <form action="/admin/categories/<%= categoryItem.id %>/delete" method="POST">
              <button type="submit" class="btn-danger">Remove</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="admin-card" style="grid-column: 1 / -1;">
      <h2>Current Products</h2>
      <% if (!products.length) { %>
        <p>No products yet.</p>
      <% } %>

      <div class="admin-list">
        <% products.forEach((product) => { %>
          <article class="admin-item">
            <div>
              <h3><a href="/products/<%= product.id %>" style="text-decoration:none;color:inherit;"><%= product.name %></a></h3>
              <p class="meta">R <%= Number(product.price).toFixed(2) %> &bull; <%= product.gender %> &bull; <%= product.in_stock ? 'In stock' : 'Out of stock' %></p>
            </div>

            <form action="/admin/products/<%= product.id %>/update" method="POST" enctype="multipart/form-data" class="edit-form">
              <input type="text" name="name" value="<%= product.name %>" required />
              <textarea name="description" rows="2" placeholder="Optional"><%= product.description %></textarea>
              <input type="number" name="price" min="1" step="0.01" value="<%= Number(product.price).toFixed(2) %>" required />
              <input type="text" name="options" value="<%= product.optionsArray.join(', ') %>" required />
              <% const isCustomCategory = !categoryOptions.includes(product.gender); %>
              <select name="category" class="category-select" data-custom-target="edit-custom-<%= product.id %>" required>
                <option value="">Select category</option>
                <% categoryOptions.forEach((categoryOption) => { %>
                  <option value="<%= categoryOption %>" <%= product.gender === categoryOption ? 'selected' : '' %>><%= categoryOption %></option>
                <% }) %>
                <option value="__custom__" <%= isCustomCategory ? 'selected' : '' %>>Other (custom)</option>
              </select>
              <input
                id="edit-custom-<%= product.id %>"
                class="custom-category-field <%= isCustomCategory ? '' : 'hidden' %>"
                type="text"
                name="customCategory"
                value="<%= isCustomCategory ? product.gender : '' %>"
                placeholder="Type custom category"
              />
              <label class="checkbox-line">
                <input type="checkbox" name="inStock" value="1" <%= product.in_stock ? 'checked' : '' %> />
                In stock
              </label>
              <label>
                Replace gallery images (up to 5)
                <input type="file" name="images" accept="image/*" multiple />
              </label>
              <button type="submit">Update</button>
            </form>

            <form action="/admin/products/<%= product.id %>/delete" method="POST" class="delete-form">
              <button type="submit" class="btn-danger">Delete</button>
            </form>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('.category-select').forEach((select) => {
      const targetId = select.dataset.customTarget;
      const target = document.getElementById(targetId);
      if (!target) {
        return;
      }

      const toggleCustomField = () => {
        if (select.value === '__custom__') {
          target.classList.remove('hidden');
        } else {
          target.classList.add('hidden');
          const input = target.querySelector('input');
          if (input) {
            input.value = '';
          }
        }
      };

      select.addEventListener('change', toggleCustomField);
      toggleCustomField();
    });
  </script>
</body>
</html>
