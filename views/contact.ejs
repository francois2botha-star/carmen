<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Carmen Boutique</title>
  <meta name="description" content="Get in touch with Carmen Boutique — WhatsApp, social media, or email. We're here to help." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <!-- NAV -->
  <nav class="top-nav">
    <a class="nav-brand" href="/">Carmen Boutique</a>
    <div class="nav-links">
      <div class="nav-dropdown">
        <a href="/">Shop</a>
        <div class="nav-submenu">
          <% categories.forEach((category) => { %>
            <a href="/?category=<%= encodeURIComponent(category) %>"><%= category %></a>
          <% }) %>
        </div>
      </div>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/cart" class="cart-link">
        🛒 Cart
        <span id="cart-badge" class="cart-badge"></span>
      </a>
      <a class="nav-wa" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">WhatsApp us</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero hero-medium">
    <div class="hero-inner">
      <h1>Get in Touch</h1>
      <p class="hero-sub">We're here to help with questions, orders, or feedback.</p>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="page-wrap">

    <!-- CONTACT METHODS -->
    <section class="section-block">
      <h2 class="section-title centered">Ways to reach us</h2>

      <div class="three-col-grid">
        <div class="feature-card pink card-centered">
          <span style="font-size: 2rem; display: block; margin-bottom: 0.7rem;">💬</span>
          <h3 style="color: var(--pink);">WhatsApp</h3>
          <p>The fastest way to reach us. We reply within minutes during business hours.</p>
          <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer" class="btn-pill-primary">Start chat</a>
        </div>

        <div class="feature-card gold card-centered">
          <span style="font-size: 2rem; display: block; margin-bottom: 0.7rem;">✉️</span>
          <h3 style="color: var(--ink);">Email</h3>
          <p>For business inquiries or detailed questions:</p>
          <p style="margin-bottom: 1rem; font-weight: 600; color: var(--ink);">hello@carmen-boutique.co.za</p>
          <a href="mailto:hello@carmen-boutique.co.za" class="btn-pill-dark">Send email</a>
        </div>

        <div class="feature-card pink card-centered">
          <span style="font-size: 2rem; display: block; margin-bottom: 0.7rem;">📱</span>
          <h3 style="color: var(--pink);">Social Media</h3>
          <p>Follow for new arrivals, style tips, and exclusive updates.</p>
          <div class="social-row">
            <a href="#" class="social-icon">IG</a>
            <a href="#" class="social-icon">FB</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-block">
      <h2 class="section-title">Frequently Asked Questions</h2>

      <div class="faq-list">
        <details class="faq-item pink">
          <summary>How long does delivery take?</summary>
          <p>
            We ship via Pudo or The Courier Guy. Delivery typically takes 2–5 business days depending on your location. You'll get tracking details once your order ships.
          </p>
        </details>

        <details class="faq-item teal">
          <summary>Do you offer returns or exchanges?</summary>
          <p>
            Yes! If an item arrives damaged or doesn't fit, we'll arrange an exchange or refund. Chat us on WhatsApp with photos and we'll sort it out.
          </p>
        </details>

        <details class="faq-item gold">
          <summary>How is shipping cost calculated?</summary>
          <p>
            Shipping costs are calculated based on your delivery location and the weight of your order. After you submit your order, we'll calculate the exact shipping fee and send you a final invoice via WhatsApp. This ships via Pudo or The Courier Guy.
          </p>
        </details>

        <details class="faq-item pink">
          <summary>Can I order outside South Africa?</summary>
          <p>
            Currently we ship within South Africa only. For international orders, reach out and we can discuss options.
          </p>
        </details>

        <details class="faq-item pink">
          <summary>How do I know my payment is safe?</summary>
          <p>
            We accept bank transfers and work with Pudo/Courier Guy's secure payment systems. Never share card details on WhatsApp—we'll send secure payment links.
          </p>
        </details>

        <details class="faq-item teal">
          <summary>What's your return policy?</summary>
          <p>
            You have 7 days from delivery to request a return or exchange. Items must be unused and in original packaging. Chat us to initiate the process.
          </p>
        </details>
      </div>
    </section>

    <!-- CTA -->
    <section class="gradient-cta">
      <h3>Still have questions?</h3>
      <p>Reach out on WhatsApp—we're always happy to chat.</p>
      <a href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer" class="btn-pill-primary">
        Message us on WhatsApp
      </a>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>Carmen Boutique</h3>
        <p>Your one-stop fashion destination — curated with love and delivered with care across South Africa.</p>
      </div>
      <div class="footer-links">
        <h4>Quick links</h4>
        <a href="/">Shop all</a>
        <a href="/about">About us</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-wa">
        <h4>Place an order</h4>
        <p>Questions? We reply fast. Chat with us directly on WhatsApp.</p>
        <a class="footer-wa-btn" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">Chat with us</a>
      </div>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Carmen Boutique &mdash; All rights reserved.</p>
  </footer>

  <script src="/cart.js"></script>

</body>
</html>
