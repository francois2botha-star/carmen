<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | Carmen Boutique</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="admin-hero">
    <h1>Admin Login</h1>
    <p>Enter password to access dashboard.</p>
    <a href="/">Back to Store</a>
  </header>

  <main style="max-width: 460px; margin: 2rem auto; padding: 0 1rem;">
    <section class="admin-card">
      <% if (error) { %>
        <p class="message error"><%= error %></p>
      <% } %>
      <form action="/admin/login" method="POST" class="admin-form">
        <label>
          Password
          <input type="password" name="password" required autofocus />
        </label>
        <button type="submit">Login</button>
      </form>
    </section>
  </main>
</body>
</html>
