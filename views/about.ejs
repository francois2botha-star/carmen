<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About Carmen Boutique</title>
  <meta name="description" content="Learn about Carmen Boutique — curated fashion, perfumes & accessories delivered across South Africa." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Raleway:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <!-- NAV -->
  <nav class="top-nav">
    <a class="nav-brand" href="/">Carmen Boutique</a>
    <div class="nav-links">
      <div class="nav-dropdown">
        <a href="/">Shop</a>
        <div class="nav-submenu">
          <% categories.forEach((category) => { %>
            <a href="/?category=<%= encodeURIComponent(category) %>"><%= category %></a>
          <% }) %>
        </div>
      </div>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/cart" class="cart-link">
        🛒 Cart
        <span id="cart-badge" class="cart-badge"></span>
      </a>
      <a class="nav-wa" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">WhatsApp us</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="hero hero-medium">
    <div class="hero-inner">
      <h1>About Carmen</h1>
      <p class="hero-sub">Passion, curated pieces, delivered with care.</p>
    </div>
  </header>

  <!-- MAIN CONTENT -->
  <main class="page-wrap">

    <!-- STORY -->
    <section class="section-block">
      <h2 class="section-title">Our Story</h2>
      <p class="content-text">
        Carmen Boutique was born from a simple belief: that fashion, fragrance, and style shouldn't be complicated.
        We wanted to create a space where you could find everything you love—beautifully curated, genuinely affordable,
        and delivered exactly when you need it.
      </p>
      <p class="content-text">
        Starting with WhatsApp as our core channel, we've built a shopping experience that feels personal, honest,
        and hassle-free. No bots. No confusing checkout. Just real humans who love fashion, helping you find your vibe.
      </p>
    </section>

    <!-- VALUES -->
    <section class="section-block">
      <h2 class="section-title">Why Carmen?</h2>
      <div class="three-col-grid">
        <div class="feature-card pink">
          <h3 style="color: var(--pink);">🛍️ Curated</h3>
          <p>Every piece is handpicked. We invest time finding exactly what matters to you.</p>
        </div>
        <div class="feature-card gold">
          <h3 style="color: var(--ink);">💬 Connected</h3>
          <p>WhatsApp means we're always just a message away. Quick replies, real conversations.</p>
        </div>
        <div class="feature-card pink">
          <h3 style="color: var(--pink);">📦 Reliable</h3>
          <p>Trusted shipping partners, fast delivery, and peace of mind every time.</p>
        </div>
      </div>
    </section>

    <!-- CATEGORIES -->
    <section class="section-block">
      <h2 class="section-title">What We Offer</h2>
      <ul class="offer-list">
        <li class="offer-item pink"><strong>Women's Clothing</strong> — Dresses, tops, trousers, and more</li>
        <li class="offer-item teal"><strong>Men's Clothing</strong> — Shirts, trousers, blazers, casuals</li>
        <li class="offer-item gold"><strong>Shoes</strong> — Flats, heels, sneakers, sandals</li>
        <li class="offer-item pink"><strong>Perfumes</strong> — Eau de parfum, fragrances, body mists</li>
        <li class="offer-item teal"><strong>Accessories</strong> — Jewelry, scarves, bags, and more</li>
      </ul>
    </section>

    <!-- CTA -->
    <section class="gradient-cta">
      <h3>Ready to explore?</h3>
      <p>Start shopping or reach out—we'd love to help.</p>
      <div class="cta-row">
        <a href="/" class="btn-pill-primary">Shop Now</a>
        <a href="/contact" class="btn-pill-secondary">Get in touch</a>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>Carmen Boutique</h3>
        <p>Your one-stop fashion destination — curated with love and delivered with care across South Africa.</p>
      </div>
      <div class="footer-links">
        <h4>Quick links</h4>
        <a href="/">Shop all</a>
        <a href="/about">About us</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-wa">
        <h4>Place an order</h4>
        <p>Questions? We reply fast. Chat with us directly on WhatsApp.</p>
        <a class="footer-wa-btn" href="https://wa.me/<%= whatsappNumber %>" target="_blank" rel="noopener noreferrer">Chat with us</a>
      </div>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> Carmen Boutique &mdash; All rights reserved.</p>
  </footer>

  <script src="/cart.js"></script>

</body>
</html>
